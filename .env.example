# All variables are optional — with none set, the app runs in open mockup mode.

# PostgreSQL connection string (Supabase, Neon, Railway, or self-managed).
# Enables persistence and durable sessions. Apply migrations with: npm run db:migrate
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Setting a password turns on the login gate for the whole app and API.
# DASHBOARD_PASSWORD=choose-a-strong-password

# Required in production when DASHBOARD_PASSWORD is set, so sessions survive restarts.
# SESSION_SECRET=long-random-string

# Sentry error monitoring. Off when unset.
# SENTRY_DSN=

# In-process scheduled jobs (data collection in later phases). Off when unset.
# JOBS_ENABLED=1

# Port for the combined server (API + client). Defaults to 5000.
# PORT=5000

# SportsGameOdds API key (provider verification + later data collection).
# SPORTSGAMEODDS_API_KEY=

# Max MLB events fetched per collection run (1-10, default 3). Each run is
# one metered API request; more events = more stored odds rows.
# ODDS_EVENTS_LIMIT=3

# Automatic collection cadence in minutes (min 10). Leave unset to collect
# manually via GET /api/collect/run. Requires JOBS_ENABLED=1.
# COLLECT_INTERVAL_MIN=30

# The Odds API key (the-odds-api.com) — Hard Rock Bet verification and,
# once confirmed, a second collection source. Free tier: 500 credits/month.
# THEODDSAPI_KEY=

# Bookmakers you can actually bet (comma-separated IDs). All collected books
# feed the consensus; only these surface as opportunities.
# Default: hardrockbet,fliff (Florida — add hardrockbet_oh only if betting from Ohio)
# MY_BOOKMAKERS=hardrockbet,fliff

# Claude API key (console.anthropic.com) — enables parsing trend screenshots
# on the Trends page. Manual trend entry works without it.
# ANTHROPIC_API_KEY=
# Override the vision model used for trend parsing (default claude-opus-4-8).
# TREND_PARSER_MODEL=claude-opus-4-8
